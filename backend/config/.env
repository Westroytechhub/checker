# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=bece_checker
DB_PORT=3306

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Mobile Money APIs
MTN_API_KEY=your_mtn_api_key
MTN_API_URL=https://api.mtn.com/v1

VODAFONE_API_KEY=your_vodafone_api_key
VODAFONE_API_URL=https://api.vodafone.com/v1

AIRTEL_API_KEY=your_airtel_api_key
AIRTEL_API_URL=https://api.airtel.com/v1

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=BECE Checker
SMTP_FROM_EMAIL=noreply@becechecker.com

# Logging
LOG_LEVEL=info
LOG_PATH=logs/